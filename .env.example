# GitHub API Token (required for comment submission feature)
# Create a token at: https://github.com/settings/tokens
# Requires: public_repo scope (to create issues in the public repo)
# Only needed if running the server locally with comment submission enabled
GITHUB_TOKEN=github_pat_your_token_here

# Port (optional, defaults to 3000)
PORT=3000

# Node Environment
NODE_ENV=production
